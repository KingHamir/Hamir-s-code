void slowPrint(const std::string& text, int ms = 20) {
for (char c : text) {
std::cout << c << std::flush;
std::this_thread::sleep_for(std::chrono::milliseconds(ms));
}
}

void fakeLoading(int seconds = 1) {
std::cout << "[";
for (int i = 0; i < 10; ++i) {
std::this_thread::sleep_for(std::chrono::milliseconds(seconds * 50));
std::cout << "#" << std::flush;
}
std::cout << "] Done.\n";
}

// -------------------------------------------------------------
// Password validation
// -------------------------------------------------------------
bool isValidPassword(const std::string& pwd) {
if (pwd.length() < 8 || pwd.length() > 20) return false;
bool hasUpper = false, hasLower = false, hasDigit = false;
for (char c : pwd) {
if (std::isupper(static_cast<unsigned char>(c))) hasUpper = true;
else if (std::islower(static_cast<unsigned char>(c))) hasLower = true;
else if (std::isdigit(static_cast<unsigned char>(c))) hasDigit = true;
}
return hasUpper && hasLower && hasDigit;
}

void showRules() {
std::cout << "\n=== PASSWORD RULES ===\n"
