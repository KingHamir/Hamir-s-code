bool handleSecret(const std::string& input, bool& wasSecret) {
wasSecret = false;
auto allSecrets = getAllSecrets();
for (const auto& secret : allSecrets) {
if (input == secret.trigger) {
if (foundSecrets.find(secret.trigger) == foundSecrets.end()) {
foundSecrets.insert(secret.trigger);
saveData();
}
std::cout << "\n" << secret.message << "\n\n";
wasSecret = true;
return true;
}
}
return false;
}

// Show found secrets AND hints for unfound ones
void showSecretsFound() {
auto allSecrets = getAllSecrets();
if (foundSecrets.empty()) {
std::cout << "\nYou haven't found any secrets yet.\n";
} else {
std::cout << "\n=== SECRETS YOU HAVE FOUND (" << foundSecrets.size() << " of " << allSecrets.size() << ") ===\n";
for (const auto& s : foundSecrets) {
std::cout << " [X] " << s << "\n";
}
std::cout << "========================================\n\n";
}

// Show hints for secrets not yet found
std::vector<SecretInfo> notFound;
for (const auto& secret : allSecrets) {
if (foundSecrets.find(secret.trigger) == foundSecrets.end()) {
notFound.push_back(secret);
}
}

if (!notFound.empty()) {
std::cout << "=== HINTS FOR SECRETS YOU HAVEN'T FOUND (" << notFound.size() << " left) ===\n";
for (const auto& secret : notFound) {
std::cout << " [?] " << secret.hint << "\n";
}
std::cout << "================================================\n\n";
std::cout << "Type any of those words (or numbers) during password creation to unlock the secret!\n";
} else {
std::cout << "Amazing! You found every secret! You're a true explorer.\n";
}
}

// -------------------------------------------------------------
// MAIN PROGRAM
// -------------------------------------------------------------
int main() {
std::srand(static_cast<unsigned>(std::time(nullptr)));
loadSavedData();

std::string password, verification;

// Welcome
slowPrint("Welcome to the Super Silly Password Creator (School Edition).\n", 15);
slowPrint("Type 'showsecrets' anytime to see which secrets you've discovered and get hints for the rest.\n", 15);
slowPrint("All jokes are clean and friendly. Have fun!\n", 15);
fakeLoading(1);
std::cout << "\n";

// ----- Password creation -----
while (true) {
showRules();
std::cout << "Create your password: ";
std::getline(std::cin, password);

// Special command to show secrets
if (password == "showsecrets") {
showSecretsFound();
continue;
}

// Check for secrets
bool wasSecret = false;
if (handleSecret(password, wasSecret)) {
if (wasSecret) continue; // secret triggered, loop again
}

// Not a secret, validate password
if (isValidPassword(password)) {
std::cout << "\n[SUCCESS] Password accepted!\n";
savedPassword = password;
saveData();
break;
} else {
std::cout << "\n[ERROR] Invalid password. ";
if (password.length() < 8) std::cout << "Too short. ";
if (password.length() > 20) std::cout << "Too long. ";
if (!std::any_of(password.begin(), password.end(), ::isupper)) std::cout << "No uppercase. ";
if (!std::any_of(password.begin(), password.end(), ::islower)) std::cout << "No lowercase. ";
if (!std::any_of(password.begin(), password.end(), ::isdigit)) std::cout << "No number. ";
std::cout << "Try again.\n";
}
}

// ----- Verification phase (max 3 attempts) -----
const int MAX_ATTEMPTS = 3;
int attempts = 0;
bool verified = false;

std::cout << "\n--- VERIFICATION PHASE ---\n";
while (attempts < MAX_ATTEMPTS && !verified) {
std::cout << "Verify your password (attempt " << (attempts + 1) << " of " << MAX_ATTEMPTS << "): ";
std::getline(std::cin, verification);

if (verification == password) {
verified = true;
std::cout << "\n[SUCCESS] Password successfully verified!\n";
slowPrint("Your password is now locked in. Secrets have been saved. Goodbye!\n", 15);
} else {
attempts++;
if (attempts < MAX_ATTEMPTS) {
std::cout << "[ERROR] Incorrect. ";
if (attempts == 1) std::cout << "Take a deep breath and try again.\n";
if (attempts == 2) std::cout << "Last chance!\n";
}
}
}

if (!verified) {
std::cout << "\n[ERROR] Too many failed attempts. Exiting without saving password.\n";
return 1;
}

// Final  message
std::cout << "\nThanks for using the password program.\n";
std::cout << "You found " << foundSecrets.size() << " secret(s) out of " << getAllSecrets().size() << ". Keep being curious!\n";

return 0;
}
