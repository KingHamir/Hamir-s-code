#include <iostream>
#include <string>
#include <cctype>
#include <fstream>

using namespace std;

bool isValidPassword(const string& pwd) {
if (pwd.length() < 8 || pwd.length() > 20) return false;
bool hasUpper = false, hasLower = false, hasDigit = false;
for (char c : pwd) {
if (isupper(static_cast<unsigned char>(c))) hasUpper = true;
else if (islower(static_cast<unsigned char>(c))) hasLower = true;
else if (isdigit(static_cast<unsigned char>(c))) hasDigit = true;
}
return hasUpper && hasLower && hasDigit;
}

void appendPassword(const string& pwd) {
ofstream out("passwords.txt", ios::app);
if (out.is_open()) {
out << pwd << endl;
out.close();
}
}

int main() {
cout << "Password Manager (add new passwords, type 0 to exit)\n\n";
cout << "Password requirements:\n"
<< " - 8 to 20 characters\n"
<< " - at least one uppercase letter\n"
<< " - at least one lowercase letter\n"
<< " - at least one digit\n\n";

while (true) {
cout << "----------------------------------------\n";
cout << "Enter 0 to quit, or press Enter to add a new password.\n";
string choice;
getline(cin, choice);
if (choice == "0") {
cout << "Goodbye.\n";
break;
}

// Create a valid password
string password;
while (true) {
cout << "Create your password: ";
getline(cin, password);
if (isValidPassword(password)) {
cout << "Password accepted.\n";
break;
} else {
cout << "Invalid password. Please follow the rules.\n";
}
}

// Verification: first attempt is required
cout << "\nVerify your password: ";
string verify;
getline(cin, verify);
if (verify == password) {
cout << "Verification successful. Password saved.\n";
appendPassword(password);
} else {
// First attempt failed: give up to 2 extra attempts (total 3)
const int EXTRA_ATTEMPTS = 2;
bool verified = false;
for (int attempt = 1; attempt <= EXTRA_ATTEMPTS && !verified; ++attempt) {
cout << "Incorrect. " << (EXTRA_ATTEMPTS - attempt + 1) << " attempt(s) left.\n";
cout << "Re-enter your password: ";
getline(cin, verify);
if (verify == password) {
verified = true;
cout << "Verification successful. Password saved.\n";
appendPassword(password);
}
}
if (!verified) {
cout << "Too many failed attempts. This password was not saved.\n";
}
}

cout << endl;
}

return 0;
}

