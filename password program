<< "* At least one number (0-9)\n"
<< "======================\n\n";
}

// -------------------------------------------------------------
// Persistent storage for password and secrets
// -------------------------------------------------------------
std::string savedPassword = "";
std::set<std::string> foundSecrets; // stores the secret trigger words

void loadSavedData() {
std::ifstream in("passwords");
if (!in.is_open()) return;
std::string line;
// first line: password
if (std::getline(in, line)) {
savedPassword = line;
}
// remaining lines: secret triggers
while (std::getline(in, line)) {
if (!line.empty() && line != "---SECRETS---") {
foundSecrets.insert(line);
}
}
in.close();
}

void saveData() {
std::ofstream out("passwords");
if (!out.is_open()) {
std::cout << "[NOTE] Could not save data.\n";
return;
}
// save current password (if any)
out << savedPassword << "\n";
out << "---SECRETS---\n";
for (const auto& s : foundSecrets) {
out << s << "\n";
}
out.close();
}

