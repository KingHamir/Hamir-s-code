//Gets a single character input from user and converts to integer
int getSingleCharInput() {
char c;
cin >> c;
cin.ignore(numeric_limits<streamsize>::max(), '\n'); // Clear input buffer
if(c >= '0' && c <= '9') return c - '0';
return -1;
}
