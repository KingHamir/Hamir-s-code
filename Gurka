//make sure the cards play is valid
bool isValidMove(int player, int cardIndex, int highestValue) {
int cardVal = playerHandValues[player][cardIndex];
int lowestIdx = findLowestCardIndex(player);

// Leading player can play any card
if(highestValue == 0) return true;

// Can play card if it's >= highest card
if(cardVal >= highestValue) return true;

// Can play lowest card as a special case
if(cardIndex == lowestIdx) return true;

return false;
}

//bots
int getAICardChoice(int player, int highestValue) {
int validMoves[6]; // Store indices of valid cards
int validCount = 0;

// Find all valid cards
for(int i = 0; i < playerHandSize[player]; i++) {
if(isValidMove(player, i, highestValue)) {
validMoves[validCount] = i;
validCount++;
}
}

// Return first valid card (or 0 if none found)
if(validCount == 0) return 0;
return validMoves[rand() % validCount];
}

