/**
* Displays all cards in a player's hand
* @param player - Player index
*/
void showPlayerHand(int player) {
cout << "\nYour cards:\n\n";
for(int i = 0; i < playerHandSize[player]; i++) {
cout << "Card " << (i + 1) << ":\n";
printCard(playerHandValues[player][i], playerHandSuits[player][i]);
cout << "\n";
}
}

// ========== MAIN GAME FUNCTIONS ==========

/**
* Main game controller - manages game flow and rounds
*/
void game() {
// Setup based on game mode
if(game_mode == 1) setupSinglePlayer();
else setupMultiplayer();

// Initialize game state
for(int i = 0; i < 8; i++) {
playerScores[i] = 0;
playerEliminated[i] = 0;
playerHandSize[i] = 0;
}
currentDealer = 0;

cout << "\n========================================\n";
cout << " Game started with " << player_count << " players!\n";
cout << "========================================\n\n";

// Continue game until only one player remains
while(countActivePlayers() > 1) {
cout << "\n\n========================================\n";
cout << " NEW ROUND - Dealer: " << playerNames[currentDealer] << "\n";
cout << "========================================\n";

showScores(); // Display current scores
dealCards(); // Deal cards for this round
playRound(); // Play all tricks in this round
checkEliminations(); // Check for players who reached 30 points

// Move to next dealer, skip eliminated players
currentDealer = (currentDealer + 1) % player_count;
while(playerEliminated[currentDealer] == 1 && countActivePlayers() > 1) {
currentDealer = (currentDealer + 1) % player_count;
}

cout << "\nPress Enter to continue...";
cin.get();
}

// Announce winner
for(int i = 0; i < player_count; i++) {
if(playerEliminated[i] == 0) {
cout << "\n\n========================================\n";
cout << "== GAME OVER! ==\n";
cout << "== " << playerNames[i] << " WINS THE GAME! ==\n";
cout << "========================================\n\n";
break;
}
}
}

/**
* Deals 6 cards to each active player from shuffled deck
*/
void dealCards() {
deckSize = 0;
for(int i = 0; i < 8; i++) playerHandSize[i] = 0;

// Create standard 52-card deck
char suits[4] = {'S', 'D', 'C', 'H'};
for(int s = 0; s < 4; s++) {
for(int v = 2; v <= 14; v++) {
deckValues[deckSize] = v;
deckSuits[deckSize] = suits[s];
deckSize++;
}
}

// Fisher-Yates shuffle algorithm
for(int i = deckSize - 1; i > 0; i--) {
int j = rand() % (i + 1);
swap(deckValues[i], deckValues[j]);
swap(deckSuits[i], deckSuits[j]);
}

// Deal cards to active players (6 cards each)
int deckIndex = 0;
for(int cardNum = 0; cardNum < 6; cardNum++) {
for(int p = 0; p < player_count; p++) {
if(playerEliminated[p] == 0) {
playerHandValues[p][playerHandSize[p]] = deckValues[deckIndex];
playerHandSuits[p][playerHandSize[p]] = deckSuits[deckIndex];
playerHandSize[p]++;
deckIndex++;
}
}
}

cout << "\nCards have been dealt! Each player has 6 cards.\n";
}

/**
* Plays all tricks in a round
* Each trick: players play cards, highest card wins, winner leads next trick
*/
void playRound() {
// Determine who starts (player after dealer)
int startPlayer = (currentDealer + 1) % player_count;
while(playerEliminated[startPlayer] == 1) startPlayer = (startPlayer + 1) % player_count;

int trickNum = 0;
int playerRoundPoints[8] = {0}; // Track points earned this round

// Continue until all cards are played
while(1) {
// Check if any active players have cards left
int handsEmpty = 1;
for(int p = 0; p < player_count; p++) {
if(playerEliminated[p] == 0 && playerHandSize[p] > 0) {
handsEmpty = 0;
break;
}
}
if(handsEmpty == 1) break;

trickNum++;
cout << "\n\n----------------------------------------\n";
cout << " TRICK " << trickNum << "\n";
cout << "----------------------------------------\n";

// Arrays to track the current trick
int trickPlayers[8], trickValues[8];
char trickSuits[8];
int trickSize = 0;
int highestValue = 0;
int currentPlayer = startPlayer;
int trickWinner = startPlayer;
int activePlayers = countActivePlayers();

// Each player plays one card
for(int turn = 0; turn < activePlayers; turn++) {
// Skip eliminated players and those with no cards
while(playerEliminated[currentPlayer] == 1) currentPlayer = (currentPlayer + 1) % player_count;
if(playerHandSize[currentPlayer] == 0) {
currentPlayer = (currentPlayer + 1) % player_count;
continue;
}

cout << "\n" << playerNames[currentPlayer] << "'s turn";
if(game_mode == 1 && currentPlayer == humanPlayer) cout << " (YOU)";
cout << "\n----------------------------------------\n";

// Show highest card to beat
if(highestValue == 0) cout << "Highest card to beat: None (leading)\n";
else cout << "Highest card to beat: " << getCardName(highestValue) << "\n";

int cardIndex = -1;
bool isAI = (game_mode == 1 && currentPlayer != humanPlayer);

// AI or Human move
if(isAI) {
cardIndex = getAICardChoice(currentPlayer, highestValue);
cout << "\n" << playerNames[currentPlayer] << " is thinking...\n";
} else {
showPlayerHand(currentPlayer);
// Keep asking until valid move is chosen
while(1) {
cout << "\nChoose a card to play (1-" << playerHandSize[currentPlayer] << "): ";
cardIndex = getSingleCharInput() - 1;
if(cardIndex < 0 || cardIndex >= playerHandSize[currentPlayer]) {
cout << "\nInvalid choice!\n";
continue;
}
if(isValidMove(currentPlayer, cardIndex, highestValue)) break;

int lowestIdx = findLowestCardIndex(currentPlayer);
cout << "\nINVALID MOVE! Must play card >= " << getCardName(highestValue);
cout << " OR play lowest card (" << getCardName(playerHandValues[currentPlayer][lowestIdx]) << ")\n";
}
}

// Play the selected card
int playedValue = playerHandValues[currentPlayer][cardIndex];
char playedSuit = playerHandSuits[currentPlayer][cardIndex];
removeCardFromHand(currentPlayer, cardIndex);

cout << "\n>>> " << playerNames[currentPlayer] << " plays:\n";
printCard(playedValue, playedSuit);

// Record the played card
trickPlayers[trickSize] = currentPlayer;
trickValues[trickSize] = playedValue;
trickSuits[trickSize] = playedSuit;
trickSize++;

// Update highest card and potential winner
if(playedValue >= highestValue) {
highestValue = playedValue;
trickWinner = currentPlayer;
}

currentPlayer = (currentPlayer + 1) % player_count;
}

// Announce trick winner
cout << "\n========================================\n";
cout << playerNames[trickWinner] << " wins trick " << trickNum << "!\n";
cout << "========================================\n";

// Award penalty points to all non-winners
for(int i = 0; i < trickSize; i++) {
int p = trickPlayers[i];
if(p != trickWinner) {
int pts = trickValues[i];
playerScores[p] += pts;
playerRoundPoints[p] += pts;
}
}

// Winner leads next trick
startPlayer = trickWinner;
}

// Display round summary
cout << "\n========================================\n";
cout << " ROUND SUMMARY\n";
cout << "========================================\n\n";
for(int p = 0; p < player_count; p++) {
if(playerEliminated[p] == 1) continue;
cout << " " << playerNames[p] << ": +" << playerRoundPoints[p] << " this round, Total: " << playerScores[p];
if(playerScores[p] >= 30) cout << " <-- CUCUMBER!";
cout << "\n";
}
cout << "========================================\n\n";
}

/**
* Removes a card from a player's hand by shifting remaining cards left
* @param player - Player index
* @param cardIndex - Index of card to remove
*/
void removeCardFromHand(int player, int cardIndex) {
for(int i = cardIndex; i < playerHandSize[player] - 1; i++) {
playerHandValues[player][i] = playerHandValues[player][i + 1];
playerHandSuits[player][i] = playerHandSuits[player][i + 1];
}
playerHandSize[player]--;
}

/**
* Finds the index of the lowest value card in a player's hand
* @param player - Player index
* @return Index of lowest card
*/
int findLowestCardIndex(int player) {
int lowestIdx = 0;
int lowestVal = playerHandValues[player][0];
for(int i = 1; i < playerHandSize[player]; i++) {
if(playerHandValues[player][i] < lowestVal) {
lowestVal = playerHandValues[player][i];
lowestIdx = i;
}
}
return lowestIdx;
}

/**
* Converts card value to readable name
* @param value - Card value (2-14)
* @return String name (Ace, King, Queen, Jack, or number)
*/
string getCardName(int value) {
if(value == 11) return "Jack";
if(value == 12) return "Queen";
if(value == 13) return "King";
if(value == 14) return "Ace";
return to_string(value);
}

/**
* Checks and eliminates players who have reached 30 or more points
* Eliminated players become "cucumbers" and are out of the game
*/
void checkEliminations() {
for(int p = 0; p < player_count; p++) {
if(playerEliminated[p] == 0 && playerScores[p] >= 30) {
cout << "\n========================================\n";
cout << playerNames[p] << " has " << playerScores[p] << " points and is a CUCUMBER!\n";
cout << playerNames[p] << " is ELIMINATED!\n";
cout << "========================================\n\n";
playerEliminated[p] = 1;
}
}
}


//Counts how many players are still active (not eliminated)
int countActivePlayers() {
int count = 0;
for(int p = 0; p < player_count; p++) {
if(playerEliminated[p] == 0) count++;
}
return count;
}

/**
* Displays current scores for all players
*/
void showScores() {
cout << "\n----------------------------------------\n";
cout << " CURRENT SCORES\n";
cout << "----------------------------------------\n";
for(int p = 0; p < player_count; p++) {
cout << " " << playerNames[p] << ": ";
if(playerEliminated[p] == 0) {
cout << playerScores[p] << " points";
if(playerScores[p] >= 20) cout << " (DANGER!)"; // Warning when close to elimination
} else {
cout << "ELIMINATED";
}
cout << "\n";
}
cout << "----------------------------------------\n\n";
}

