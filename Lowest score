// 3. Drop Lowest Score (modified from #2)
#include <iostream>
#include <algorithm>

void sortScores(int* scores, int size) {
std::sort(scores, scores + size);
}

double calculateAverageDropLowest(int* scores, int size) {
// lowest is scores[0] after sorting
int sum = 0;
for (int i = 1; i < size; ++i) // start at index 1 (skip lowest)
sum += *(scores + i);
return static_cast<double>(sum) / (size - 1);
}

int main() {
int numScores;
std::cout << "Enter number of test scores: ";
std::cin >> numScores;

int* scores = new int[numScores];
for (int i = 0; i < numScores; ++i) {
do {
std::cout << "Score " << i+1 << ": ";
std::cin >> *(scores + i);
if (*(scores + i) < 0)
std::cout << "Invalid (negative). Try again.\n";
} while (*(scores + i) < 0);
}

sortScores(scores, numScores);
double avg = calculateAverageDropLowest(scores, numScores);

std::cout << "\nSorted scores (lowest dropped for average):\n";
for (int i = 0; i < numScores; ++i)
std::cout << *(scores + i) << ' ';
std::cout << "\nAverage (excluding lowest): " << avg << std::endl;

delete[] scores;
return 0;
}
